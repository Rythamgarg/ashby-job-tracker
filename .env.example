# Copy this file to .env and fill in your real values.
# Never commit the actual .env file.

# Anthropic API key (for resume-matching) -- console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# SMTP settings for sending the digest email.
# For Gmail: enable 2FA, then create an "App Password" at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_TO=youraddress@gmail.com

# Optional: minimum relevance score (0-100) to include a job in the digest
MIN_MATCH_SCORE=60
